# Godot cache — never commit these
.godot/
*.import
*.uid

# Exported binaries — tracked as zips in builds/ only
builds/*.exe
builds/*.pck

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*.Zone.Identifier

# VS Code
.vscode/

# JetBrains
.idea/

# Node modules (MCP server)
mcp/node_modules/

# Tool config
opencode.json
